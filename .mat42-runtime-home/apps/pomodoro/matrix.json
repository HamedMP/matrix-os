{
  "name": "Pomodoro Timer",
  "description": "Focus timer with session tracking",
  "category": "productivity",
  "icon": "pomodoro-timer",
  "author": "system",
  "version": "2.0.0",
  "storage": {
    "tables": {
      "sessions": {
        "columns": {
          "duration": "integer",
          "type": "text",
          "completed": "boolean"
        },
        "indexes": [
          "type"
        ]
      }
    }
  },
  "runtime": "vite",
  "slug": "pomodoro",
  "runtimeVersion": "^1.0.0",
  "listingTrust": "first_party",
  "build": {
    "install": "true",
    "command": "vite build --base ./ --outDir dist",
    "output": "dist",
    "timeout": 180,
    "sourceGlobs": [
      "src/**",
      "../_shared/**",
      "../../_shared/**",
      "index.html",
      "matrix.json",
      "vite.config.ts"
    ]
  }
}

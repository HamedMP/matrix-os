{
  "name": "Expense Tracker",
  "description": "Track daily expenses and budgets",
  "category": "productivity",
  "icon": "expense-tracker",
  "author": "system",
  "version": "2.0.0",
  "storage": {
    "tables": {
      "expenses": {
        "columns": {
          "amount": "float",
          "description": "text",
          "category": "text",
          "date": "timestamptz"
        },
        "indexes": [
          "date",
          "category"
        ]
      }
    }
  },
  "runtime": "vite",
  "slug": "expense-tracker",
  "runtimeVersion": "^1.0.0",
  "listingTrust": "first_party",
  "build": {
    "install": "true",
    "command": "vite build --base ./ --outDir dist",
    "output": "dist",
    "timeout": 180,
    "sourceGlobs": [
      "src/**",
      "../_shared/**",
      "../../_shared/**",
      "index.html",
      "matrix.json",
      "vite.config.ts"
    ]
  }
}

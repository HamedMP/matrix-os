{
  "name": "Symphony",
  "description": "Matrix-native Linear ticket orchestration with Codex agents and managed worktrees",
  "category": "developer",
  "icon": "code",
  "author": "system",
  "version": "1.0.0",
  "runtime": "vite",
  "slug": "symphony",
  "runtimeVersion": "^1.0.0",
  "scope": "personal",
  "build": {
    "install": "pnpm install --ignore-workspace --prefer-offline",
    "command": "pnpm build",
    "output": "dist",
    "timeout": 180
  },
  "integrations": {
    "required": [
      "linear"
    ]
  },
  "permissions": [
    "matrix.projects",
    "matrix.worktrees",
    "matrix.agents"
  ],
  "listingTrust": "first_party"
}

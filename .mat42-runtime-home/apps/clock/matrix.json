{
  "name": "Clock",
  "description": "Analog and digital clock with timer",
  "runtime": "vite",
  "category": "utility",
  "icon": "clock",
  "author": "system",
  "version": "1.0.0",
  "slug": "clock",
  "runtimeVersion": "^1.0.0",
  "listingTrust": "first_party",
  "build": {
    "install": "true",
    "command": "vite build --base ./ --outDir dist",
    "output": "dist",
    "timeout": 180,
    "sourceGlobs": [
      "src/**",
      "../_shared/**",
      "../../_shared/**",
      "index.html",
      "matrix.json",
      "vite.config.ts"
    ]
  }
}

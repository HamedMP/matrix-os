{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(matrix_release_channel_info)", "refId": "A" }],
      "title": "Promoted Channels",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "decbytes" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["max"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(matrix_release_channel_bundle_bytes)", "refId": "A" }],
      "title": "Largest Bundle",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 0 },
      "id": 3,
      "options": {
        "content": "Upgrade actions are still intentionally outside Grafana. Use the platform release endpoints for now; this dashboard shows the exact channel target and version drift data needed for a future controlled action panel.",
        "mode": "markdown"
      },
      "title": "Upgrade Action Boundary",
      "type": "text"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "filterable": true } }, "overrides": [] },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
      "id": 4,
      "options": { "showHeader": true, "sortBy": [{ "displayName": "channel" }] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "matrix_release_channel_info", "format": "table", "instant": true, "refId": "A" }],
      "title": "Channel Pointers",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Value": true, "__name__": true, "instance": true, "job": true },
            "indexByName": { "channel": 0, "version": 1, "git_ref": 2, "git_commit": 3, "severity": 4 }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 13 },
      "id": 5,
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "pieType": "pie", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count by (version) (matrix_vps_info)", "legendFormat": "{{version}}", "refId": "A" }],
      "title": "Installed VPS Versions",
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "decbytes" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 13 },
      "id": 6,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "matrix_release_channel_bundle_bytes", "legendFormat": "{{channel}} {{version}}", "refId": "A" }],
      "title": "Bundle Size by Channel",
      "type": "timeseries"
    }
  ],

      "targets": [
        {
          "expr": "matrix_vps_info",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "matrix_vps_healthy",
          "format": "table",
          "instant": true,
          "refId": "B"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "Value #A": true
            },
            "renameByName": {
              "Value #B": "healthy"
            }
          }
        }
      ]
    },
    {
      "datasource": {

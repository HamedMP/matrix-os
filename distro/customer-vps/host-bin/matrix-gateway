#!/usr/bin/env bash
set -euo pipefail

source /opt/matrix/env/host.env
if [ -f /opt/matrix/env/postgres.env ]; then
  source /opt/matrix/env/postgres.env
fi
if [ -f /opt/matrix/env/registration.env ]; then
  source /opt/matrix/env/registration.env
fi
if [ -r /opt/matrix/bin/matrix-owner-env ]; then
  source /opt/matrix/bin/matrix-owner-env
fi

NODE_BIN="${MATRIX_NODE_BIN:-/opt/matrix/runtime/node/bin/node}"
APP_DIR="${MATRIX_APP_DIR:-/opt/matrix/app}"
GATEWAY_PORT="${PORT:-4000}"
REGISTER_FLAG="/opt/matrix/register-complete"

export NODE_ENV="${NODE_ENV:-production}"
export MATRIX_HOME="${MATRIX_HOME:-/home/matrix/home}"
if declare -F matrix_export_owner_env >/dev/null 2>&1; then
  matrix_export_owner_env
  if declare -F matrix_reconcile_owner_home >/dev/null 2>&1; then
    matrix_reconcile_owner_home "${MATRIX_RUNTIME_USER:-matrix}" "${MATRIX_RUNTIME_GROUP:-${MATRIX_RUNTIME_USER:-matrix}}"
  fi
else
  export HOME="$MATRIX_HOME"
fi
export MATRIX_USER_ID="${MATRIX_USER_ID:-$MATRIX_CLERK_USER_ID}"
export MATRIX_HANDLE
if [ -z "${DATABASE_URL:-}" ] && [ -n "${POSTGRES_USER:-}" ] && [ -n "${POSTGRES_PASSWORD:-}" ] && [ -n "${POSTGRES_DB:-}" ]; then
  export DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@127.0.0.1:5432/${POSTGRES_DB}"
else
  export DATABASE_URL="${DATABASE_URL:-}"
fi
export PORT="$GATEWAY_PORT"
export GATEWAY_URL="${GATEWAY_URL:-http://127.0.0.1:${GATEWAY_PORT}}"
export NEXT_PUBLIC_GATEWAY_URL="${NEXT_PUBLIC_GATEWAY_URL:-http://127.0.0.1:${GATEWAY_PORT}}"
export NEXT_PUBLIC_GATEWAY_WS="${NEXT_PUBLIC_GATEWAY_WS:-wss://code.matrix-os.com/ws}"
if declare -F matrix_prepend_path_once >/dev/null 2>&1; then
  matrix_prepend_path_once "/opt/matrix/app/node_modules/.bin"
else
  export PATH="$MATRIX_HOME/.local/bin:/opt/matrix/bin:/opt/matrix/app/node_modules/.bin:/opt/matrix/runtime/node/bin:/usr/local/bin:$PATH"
fi

sync_bundled_home_assets() {
  local script_dir sync_script
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  sync_script="${MATRIX_SYNC_BUNDLED_HOME_ASSETS:-$script_dir/matrix-sync-bundled-home-assets}"
  if [ -x "$sync_script" ]; then
    APP_DIR="$APP_DIR" MATRIX_HOME="$MATRIX_HOME" MATRIX_NODE_BIN="$NODE_BIN" "$sync_script"
  else
    echo "matrix-gateway: bundled home sync script not executable: $sync_script" >&2
    return 1
  fi

  if [ -d "$MATRIX_HOME/apps" ] && id matrix >/dev/null 2>&1; then
    chown -R matrix:matrix "$MATRIX_HOME/system/icons" "$MATRIX_HOME/apps"
  fi
}

gateway_pid=""
cleanup() {
  if [ -n "$gateway_pid" ] && kill -0 "$gateway_pid" 2>/dev/null; then
    kill "$gateway_pid"
    wait "$gateway_pid" || true
  fi
}
trap cleanup EXIT INT TERM

sync_bundled_home_assets
if [ -x "$APP_DIR/scripts/sync-matrix-agent-skills.sh" ] && [ -d "$APP_DIR/skills/matrix" ]; then
  MATRIX_SKILL_TARGETS=matrix,claude,codex \
    MATRIX_SKILLS_SOURCE="$APP_DIR/skills/matrix" \
    HOME="$MATRIX_HOME" \
    MATRIX_HOME="$MATRIX_HOME" \
    bash "$APP_DIR/scripts/sync-matrix-agent-skills.sh"
fi
if [ -f "$APP_DIR/packages/gateway/dist/shell/register-agent-bridges-cli.js" ]; then
  MATRIX_AGENT_BRIDGE_COMMAND="${MATRIX_AGENT_BRIDGE_COMMAND:-/opt/matrix/bin/matrix-agent-bridge}" \
    "$NODE_BIN" "$APP_DIR/packages/gateway/dist/shell/register-agent-bridges-cli.js" || \
    echo "matrix-gateway: agent bridge registration skipped" >&2
fi
cd "$APP_DIR"
if [ -f "$APP_DIR/packages/gateway/dist/main.js" ]; then
  "$NODE_BIN" "$APP_DIR/packages/gateway/dist/main.js" &
else
  "$NODE_BIN" --import=tsx "$APP_DIR/packages/gateway/src/main.ts" &
fi
gateway_pid="$!"

for _ in $(seq 1 90); do
  if curl --fail --silent --show-error --max-time 2 "http://127.0.0.1:${GATEWAY_PORT}/health" >/dev/null; then
    break
  fi
  if ! kill -0 "$gateway_pid" 2>/dev/null; then
    wait "$gateway_pid"
  fi
  sleep 2
done

register_once() {
  [ ! -f "$REGISTER_FLAG" ] || return 0
  [ -n "${MATRIX_PLATFORM_REGISTER_URL:-}" ] || return 0
  [ -n "${MATRIX_REGISTRATION_TOKEN:-}" ] || return 0
  case "$MATRIX_PLATFORM_REGISTER_URL" in
    */vps/register) ;;
    *) echo "matrix-gateway: MATRIX_PLATFORM_REGISTER_URL must end with /vps/register" >&2; return 1 ;;
  esac

  local instance_id public_ipv4 payload
  instance_id="$(curl --fail --silent --show-error --max-time 10 http://169.254.169.254/hetzner/v1/metadata/instance-id)"
  public_ipv4="$(curl --fail --silent --show-error --max-time 10 http://169.254.169.254/hetzner/v1/metadata/public-ipv4)"
  payload="$(printf '{"machineId":"%s","hetznerServerId":%s,"publicIPv4":"%s","imageVersion":"%s"}' \
    "$MATRIX_MACHINE_ID" "$instance_id" "$public_ipv4" "$MATRIX_IMAGE_VERSION")"

  for attempt in $(seq 1 30); do
    if curl --fail --silent --show-error --max-time 10 \
      -X POST \
      -H "authorization: Bearer ${MATRIX_REGISTRATION_TOKEN}" \
      -H "content-type: application/json" \
      --data "$payload" \
      "$MATRIX_PLATFORM_REGISTER_URL" >/dev/null; then
      touch "$REGISTER_FLAG"
      chmod 0640 "$REGISTER_FLAG"
      return 0
    fi
    sleep "$((attempt < 10 ? attempt : 10))"
  done

  echo "matrix-gateway: failed to register customer VPS after gateway startup" >&2
  return 1
}

register_once
wait "$gateway_pid"

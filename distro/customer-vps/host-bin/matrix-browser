#!/usr/bin/env bash
set -euo pipefail

export NODE_ENV="${NODE_ENV:-production}"
export PLAYWRIGHT_BROWSERS_PATH="${PLAYWRIGHT_BROWSERS_PATH:-/var/lib/matrix-browser/playwright}"
export BROWSER_RUNTIME_PORT="${BROWSER_RUNTIME_PORT:-4011}"
if [ -z "${PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH:-}" ]; then
  if command -v chromium >/dev/null 2>&1; then
    export PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH="$(command -v chromium)"
  elif command -v chromium-browser >/dev/null 2>&1; then
    export PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH="$(command -v chromium-browser)"
  fi
fi

cd /opt/matrix/app
exec /opt/matrix/runtime/node/bin/node --import tsx /opt/matrix/app/packages/mcp-browser/src/runtime-service.ts

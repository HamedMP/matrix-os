#!/usr/bin/env bash
set -euo pipefail

readonly CONFIG_PATH="/etc/nginx/sites-available/matrix"

if [ ! -f "$CONFIG_PATH" ]; then
  exit 0
fi
if [ -L "$CONFIG_PATH" ]; then
  echo "Refusing to update symlinked nginx configuration" >&2
  exit 1
fi

backup="$(mktemp /etc/nginx/sites-available/.matrix.backup.XXXXXX)"
restore_tmp=""
cleanup() {
  rm -f "$backup"
  if [ -n "$restore_tmp" ]; then
    rm -f "$restore_tmp"
  fi
}
trap cleanup EXIT
cp --preserve=mode,ownership,timestamps "$CONFIG_PATH" "$backup"

result="$(python3 - "$CONFIG_PATH" <<'PY'
import os
import stat
import sys
import tempfile

path = sys.argv[1]
with open(path, encoding="utf-8") as handle:
    text = handle.read()

lines = text.splitlines(keepends=True)
location_indexes = [
    index for index, line in enumerate(lines)
    if line.strip() == "location /api/ {"
]
if len(location_indexes) != 1:
    raise SystemExit("expected exactly one customer nginx API location")

start = location_indexes[0]
depth = 0
end = None
for index in range(start, len(lines)):
    depth += lines[index].count("{") - lines[index].count("}")
    if depth == 0:
        end = index
        break
if end is None:
    raise SystemExit("unterminated customer nginx API location")

block_lines = lines[start:end + 1]
required = (
    "proxy_http_version 1.1;",
    "proxy_set_header Upgrade $http_upgrade;",
    'proxy_set_header Connection "upgrade";',
)
if all(any(line.strip() == directive for line in block_lines) for directive in required):
    print("unchanged")
    raise SystemExit(0)

indent = block_lines[0][:-len(block_lines[0].lstrip())] + "  "
existing_directives = {line.strip() for line in block_lines}
missing = [directive for directive in required if directive not in existing_directives]
replacement_lines = [block_lines[0], *(f"{indent}{directive}\n" for directive in missing), *block_lines[1:]]
metadata = os.stat(path, follow_symlinks=False)
fd, temp_path = tempfile.mkstemp(prefix=".matrix.native-apps.", dir=os.path.dirname(path))
try:
    os.fchmod(fd, stat.S_IMODE(metadata.st_mode))
    os.fchown(fd, metadata.st_uid, metadata.st_gid)
    with os.fdopen(fd, "w", encoding="utf-8") as handle:
        handle.writelines([*lines[:start], *replacement_lines, *lines[end + 1:]])
        handle.flush()
        os.fsync(handle.fileno())
    os.replace(temp_path, path)
finally:
    if os.path.exists(temp_path):
        os.unlink(temp_path)
print("changed")
PY
)"

if [ "$result" = "unchanged" ]; then
  exit 0
fi
if [ "$result" != "changed" ]; then
  echo "Unexpected nginx configuration update result" >&2
  exit 1
fi

restore_config() {
  restore_tmp="$(mktemp /etc/nginx/sites-available/.matrix.restore.XXXXXX)"
  cp --preserve=mode,ownership,timestamps "$backup" "$restore_tmp"
  mv -f "$restore_tmp" "$CONFIG_PATH"
  restore_tmp=""
}

if ! nginx -t; then
  restore_config
  nginx -t || true
  exit 1
fi
if ! systemctl reload nginx; then
  restore_config
  nginx -t || true
  systemctl reload nginx || true
  exit 1
fi

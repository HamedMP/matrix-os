#!/usr/bin/env bash
set -euo pipefail

mode="${1:-}"
case "$mode" in
  builder|validation) ;;
  *) echo "usage: matrix-golden-snapshot-activate builder|validation" >&2; exit 64 ;;
esac
[ "$(id -u)" -eq 0 ] || { echo "golden snapshot activation requires root" >&2; exit 65; }

if [ "$mode" = validation ]; then
  sanitation_evidence=/var/lib/matrix/golden-snapshot-sanitized
  [ -f "$sanitation_evidence" ] || {
    echo "golden snapshot sanitation marker missing" >&2
    exit 66
  }
  required_clean_evidence=(
    /etc/matrix
    /opt/matrix/env
    /opt/matrix/config
    /opt/matrix/secrets
    /opt/matrix/tls
    /opt/matrix/restore-complete
    /var/lib/matrix
    /home/matrix/home
    /home/matrix/.hermes
    /home/matrix/.config
    /home/matrix/.cache
    /home/matrix/.local
    /home/matrix/.ssh
    /home/matrix/.bash_history
    /home/matrix/.zsh_history
    /home/matrix/.npmrc
    /home/matrix/.netrc
    /root/.ssh
    /root/.bash_history
    /root/.zsh_history
    /root/.npmrc
    /root/.netrc
    /var/lib/systemd/random-seed
    /var/lib/cloud
    /var/lib/dhcp
    /var/lib/NetworkManager
    /run/systemd/netif/leases
    /etc/netplan/50-cloud-init.yaml
    /etc/systemd/system/matrix-restore.service.d/golden.conf
    /run/matrix
    /var/lib/docker
    /var/lib/docker/volumes
    /var/lib/containerd
    /var/log/matrix
    /var/log/journal
    /var/log/cloud-init.log
    /var/log/cloud-init-output.log
    /var/log/matrix-builder.log
    /tmp
    /var/tmp
    '/etc/ssh/ssh_host_*'
    /etc/machine-id
    /var/lib/dbus/machine-id
    /var/lib/systemd/network
    /etc/udev/rules.d/70-persistent-net.rules
  )
  for required in "${required_clean_evidence[@]}"; do
    grep -Fqx -- "clean:$required" "$sanitation_evidence" || {
      echo "golden snapshot sanitation evidence incomplete" >&2
      exit 67
    }
  done
  for forbidden in \
    /etc/matrix \
    /opt/matrix/env \
    /opt/matrix/config \
    /opt/matrix/secrets \
    /opt/matrix/tls \
    /opt/matrix/restore-complete \
    /run/matrix/bootstrap-token \
    /home/matrix/home \
    /home/matrix/.hermes \
    /home/matrix/.config \
    /home/matrix/.cache \
    /home/matrix/.local \
    /home/matrix/.ssh \
    /home/matrix/.bash_history \
    /home/matrix/.zsh_history \
    /home/matrix/.npmrc \
    /home/matrix/.netrc \
    /root/.ssh \
    /root/.bash_history \
    /root/.zsh_history \
    /root/.npmrc \
    /root/.netrc \
    /var/log/matrix \
    /var/log/matrix-builder.log
  do
    [ ! -e "$forbidden" ] && [ ! -L "$forbidden" ] || {
      echo "golden snapshot forbidden baked state found" >&2
      exit 67
    }
  done
  cloud_instance_id="$(cloud-init query instance_id 2>/dev/null | tr -d '\r\n' || true)"
  if ! [[ "$cloud_instance_id" =~ ^[A-Za-z0-9._:-]{1,128}$ ]] \
    || [ ! -d "/var/lib/cloud/instances/$cloud_instance_id" ] \
    || [ -n "$(find /var/lib/cloud/instances -mindepth 1 -maxdepth 1 ! -name "$cloud_instance_id" -print -quit 2>/dev/null)" ]; then
    echo "golden snapshot unexpected cloud-init instance state" >&2
    exit 67
  fi
  if [ -e /var/lib/docker ] || [ -L /var/lib/docker ] \
    || [ -e /var/lib/containerd ] || [ -L /var/lib/containerd ]; then
    echo "golden snapshot baked container volume found" >&2
    exit 67
  fi
  cp "$sanitation_evidence" /run/matrix-golden-preactivation-clean
fi

# This is deliberately a synthetic, credential-free activation. It exercises
# the shipped units and binaries without platform registration, owner identity,
# object-store credentials, or provider/bootstrap tokens. All generated state
# is removed by matrix-golden-snapshot-sanitize before image creation.
getent group matrix >/dev/null || groupadd --system matrix
id matrix >/dev/null 2>&1 || useradd --system --gid matrix --home-dir /home/matrix --shell /bin/bash matrix
install -d -o matrix -g matrix -m 0750 /home/matrix/home /home/matrix/projects
install -d -o matrix -g matrix -m 0750 /opt/matrix/staging
install -d -o root -g matrix -m 0750 /opt/matrix/env
install -d -o root -g root -m 0755 /var/lib/matrix

for unit in matrix-restore.service matrix-gateway.service matrix-shell.service matrix-sync-agent.service; do
  install -o root -g root -m 0644 "/opt/matrix/systemd/$unit" "/etc/systemd/system/$unit"
done

# The production restore gate requires owner-scoped object-store credentials.
# Golden validation has no owner, so it creates a fresh local database and uses
# this narrow drop-in only for the synthetic restore gate.
install -d -o root -g root -m 0755 /etc/systemd/system/matrix-restore.service.d
cat >/etc/systemd/system/matrix-restore.service.d/golden.conf <<'EOF'
[Service]
ExecStart=
ExecStart=/usr/bin/true
EOF

synthetic_auth="$(printf '%s' "$(cat /proc/sys/kernel/random/uuid)$(cat /proc/sys/kernel/random/uuid)" | sha256sum | awk '{print $1}')"
cat >/opt/matrix/env/host.env <<EOF
MATRIX_MACHINE_ID=matrix-golden-validation
MATRIX_CLERK_USER_ID=matrix-golden-validation
MATRIX_USER_ID=matrix-golden-validation
MATRIX_HANDLE=matrix-golden-validation
MATRIX_RUNTIME_SLOT=primary
MATRIX_IMAGE_VERSION=golden-validation
MATRIX_DEVELOPER_TOOLS=''
MATRIX_AUTH_TOKEN=$synthetic_auth
MATRIX_CODE_PROXY_TOKEN=$synthetic_auth
PLATFORM_INTERNAL_URL=http://127.0.0.1:9
UPGRADE_TOKEN=$synthetic_auth
DATABASE_URL=postgresql://matrix:$synthetic_auth@127.0.0.1:5432/matrix
EOF
cat >/opt/matrix/env/postgres.env <<EOF
POSTGRES_DB=matrix
POSTGRES_USER=matrix
POSTGRES_PASSWORD=$synthetic_auth
EOF
chown root:matrix /opt/matrix/env/host.env /opt/matrix/env/postgres.env
chmod 0640 /opt/matrix/env/host.env /opt/matrix/env/postgres.env

systemctl enable --now docker.service
docker rm -f matrix-golden-postgres >/dev/null 2>&1 || true
docker run -d --name matrix-golden-postgres \
  --env-file /opt/matrix/env/postgres.env \
  -p 127.0.0.1:5432:5432 postgres:16 >/dev/null
for _ in $(seq 1 60); do
  pg_isready --host=127.0.0.1 --username=matrix >/dev/null 2>&1 && break
  sleep 2
done
pg_isready --host=127.0.0.1 --username=matrix >/dev/null

touch /opt/matrix/restore-complete
rm -f /var/lib/matrix/golden-snapshot-sanitized
systemctl daemon-reload
systemctl start matrix-restore.service matrix-gateway.service matrix-shell.service matrix-sync-agent.service

for _ in $(seq 1 90); do
  if systemctl is-active --quiet matrix-gateway.service \
    && systemctl is-active --quiet matrix-shell.service \
    && systemctl is-active --quiet matrix-sync-agent.service \
    && curl --fail --silent --show-error --max-time 2 http://127.0.0.1:4000/health >/dev/null; then
    touch /var/lib/matrix/activation-complete
    exit 0
  fi
  sleep 2
done

echo "golden snapshot synthetic activation did not become ready" >&2
exit 1

#!/usr/bin/env bash
set -euo pipefail

if [ -r /opt/matrix/env/host.env ]; then
  source /opt/matrix/env/host.env
fi

MODE="${1:-}"
if [ "$#" -gt 1 ] || { [ -n "$MODE" ] && [ "$MODE" != "--sandbox-only" ] && [ "$MODE" != "--tools-only" ]; }; then
  printf 'matrix-install-developer-tools: unsupported arguments\n' >&2
  exit 64
fi

TOOLS="${MATRIX_DEVELOPER_TOOLS-codex claude-code opencode pi}"
STATE_DIR="${MATRIX_DEVELOPER_TOOLS_STATE_DIR:-/var/lib/matrix-developer-tools}"
FAILED_FILE="$STATE_DIR/failed-tools"
INSTALLED_FILE="$STATE_DIR/installed-tools"
CODEX_VERSION="0.144.6"

log() {
  printf 'matrix-install-developer-tools: %s\n' "$*"
}

enable_ubuntu_universe() {
  [ -r /etc/os-release ] || return 0
  # shellcheck disable=SC1091 -- the host-owned OS metadata is the distro source of truth.
  . /etc/os-release
  [ "${ID:-}" = "ubuntu" ] || return 0
  timeout 300 env DEBIAN_FRONTEND=noninteractive apt-get install -y software-properties-common || return 1
  timeout 60 add-apt-repository -y universe || return 1
}

configure_bwrap_apparmor() {
  [ -r /etc/os-release ] || return 0
  # shellcheck disable=SC1091 -- the host-owned OS metadata is the distro source of truth.
  . /etc/os-release
  [ "${ID:-}" = "ubuntu" ] || return 0
  dpkg --compare-versions "$VERSION_ID" ge 24.04 || return 0

  install -d -o root -g root -m 0755 /etc/apparmor.d || return 1
  cat >/etc/apparmor.d/bwrap <<'EOF' || return 1
abi <abi/4.0>,
include <tunables/global>

profile bwrap /usr/bin/bwrap flags=(unconfined) {
  userns,
  include if exists <local/bwrap>
}
EOF
  if systemctl is-active --quiet apparmor; then
    systemctl reload apparmor || return 1
  fi
}

ensure_agent_sandbox_runtime() {
  if ! command -v bwrap >/dev/null 2>&1 || ! command -v socat >/dev/null 2>&1 || ! command -v zsh >/dev/null 2>&1; then
    command -v apt-get >/dev/null 2>&1 || {
      log "coding-agent sandbox packages are unavailable"
      return 1
    }
    timeout 300 apt-get update \
      -o Acquire::Retries=3 \
      -o Acquire::http::Timeout=20 \
      -o Acquire::https::Timeout=20 || return 1
    enable_ubuntu_universe || return 1
    timeout 300 apt-get update \
      -o Acquire::Retries=3 \
      -o Acquire::http::Timeout=20 \
      -o Acquire::https::Timeout=20 || return 1
    timeout 300 env DEBIAN_FRONTEND=noninteractive apt-get install -y bubblewrap socat zsh || return 1
  fi
  configure_bwrap_apparmor || return 1
  command -v bwrap >/dev/null 2>&1 && command -v socat >/dev/null 2>&1 && command -v zsh >/dev/null 2>&1
}

link_tool() {
  local tool="$1"
  local bin_name
  bin_name="$(tool_bin_name "$tool")"
  if [ -x "/opt/matrix/runtime/node/bin/${bin_name}" ]; then
    ln -sf "/opt/matrix/runtime/node/bin/${bin_name}" "/usr/local/bin/${bin_name}"
  fi
}

tool_bin_name() {
  local tool="$1"
  if [ "$tool" = "claude-code" ]; then
    printf 'claude\n'
    return
  fi
  printf '%s\n' "$tool"
}

codex_version_is_current() {
  local output escaped_version
  output="$(/opt/matrix/runtime/node/bin/codex --version 2>/dev/null)" || return 1
  escaped_version="${CODEX_VERSION//./\\.}"
  printf '%s\n' "$output" | grep -Eq "(^|[[:space:]])${escaped_version}([[:space:]]|$)"
}

is_tool_installed() {
  local tool="$1"
  local bin_name
  bin_name="$(tool_bin_name "$tool")"
  grep -qxF "$tool" "$INSTALLED_FILE" && [ -x "/opt/matrix/runtime/node/bin/${bin_name}" ] || return 1
  if [ "$tool" = "codex" ]; then
    codex_version_is_current
  fi
}

if [ "$MODE" != "--tools-only" ]; then
  if ! ensure_agent_sandbox_runtime; then
    log "coding-agent sandbox provisioning failed"
    exit 1
  fi
fi
if [ "$MODE" = "--sandbox-only" ]; then
  exit 0
fi

mkdir -p "$STATE_DIR"
: > "$FAILED_FILE"
touch "$INSTALLED_FILE"

failed=0
for tool in $TOOLS; do
  case "$tool" in
    codex|claude-code|opencode|pi) ;;
    *)
      log "skipping unknown developer tool id"
      continue
      ;;
  esac

  if is_tool_installed "$tool"; then
    log "optional developer tool ${tool} already installed; skipping"
    continue
  fi

  log "installing optional developer tool ${tool}"
  if /opt/matrix/bin/matrix-install-tool-pack "$tool" >>"$STATE_DIR/${tool}.log" 2>&1; then
    link_tool "$tool"
    grep -vxF "$tool" "$FAILED_FILE" >"$FAILED_FILE.tmp" || true
    mv "$FAILED_FILE.tmp" "$FAILED_FILE"
    if ! grep -qxF "$tool" "$INSTALLED_FILE"; then
      printf '%s\n' "$tool" >>"$INSTALLED_FILE"
    fi
    log "installed optional developer tool ${tool}"
  else
    failed=1
    if ! grep -qxF "$tool" "$FAILED_FILE"; then
      printf '%s\n' "$tool" >>"$FAILED_FILE"
    fi
    log "optional developer tool ${tool} failed; systemd will retry"
  fi
done

if [ "$failed" -ne 0 ]; then
  exit 1
fi

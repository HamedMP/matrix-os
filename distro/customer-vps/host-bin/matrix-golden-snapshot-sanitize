#!/usr/bin/env bash
set -euo pipefail

root="${MATRIX_GOLDEN_SNAPSHOT_ROOT:-/}"
case "$root" in
  /*) ;;
  *) echo "golden snapshot sanitation root must be absolute" >&2; exit 64 ;;
esac
root="${root%/}"
[ -n "$root" ] || root="/"
marker="$root/etc/matrix/golden-snapshot-builder"
[ -f "$marker" ] || { echo "golden snapshot builder marker missing" >&2; exit 65; }
if [ -L "$root" ]; then
  echo "golden snapshot sanitation root must not be a symlink" >&2
  exit 66
fi

under_root() {
  local relative="$1" target
  target="$root/$relative"
  case "$target" in
    "$root"/*) printf '%s\n' "$target" ;;
    *) return 1 ;;
  esac
}

remove_path() {
  local target
  target="$(under_root "$1")"
  if [ -e "$target" ] || [ -L "$target" ]; then
    rm -rf -- "$target"
  fi
}

patterns_file=""
dd_error_file=""
cleanup_runtime_evidence() {
  [ -z "$patterns_file" ] || rm -f -- "$patterns_file"
  [ -z "$dd_error_file" ] || rm -f -- "$dd_error_file"
}
trap cleanup_runtime_evidence EXIT

# Production builders seed one synthetic disk canary before deleting cloud-init
# state. Both it and the phase callback token must be absent from the raw root
# device after free-space overwrite. Patterns remain on /run tmpfs and are never
# placed in a child process argument.
if [ "$root" = "/" ]; then
  callback_token_file=/run/matrix-golden-snapshot-callback-token
  if [ ! -f "$callback_token_file" ] || [ -L "$callback_token_file" ]; then
    echo "golden snapshot callback material missing" >&2
    exit 68
  fi
  callback_token="$(<"$callback_token_file")"
  if [ "${#callback_token}" -lt 32 ] || [ "${#callback_token}" -gt 512 ]; then
    echo "golden snapshot callback material invalid" >&2
    exit 68
  fi
  storage_canary="matrix-golden-snapshot-canary-$(</proc/sys/kernel/random/uuid)"
  patterns_file=/run/matrix-golden-snapshot-scan-patterns
  umask 077
  printf '%s\n%s\n' "$callback_token" "$storage_canary" > "$patterns_file"
  install -d -m 0700 /var/lib/cloud/matrix-golden-snapshot-canary
  printf '%s\n' "$storage_canary" > /var/lib/cloud/matrix-golden-snapshot-canary/value
  sync
fi

# Matrix credentials, registration/provisioning identity, owner state, and
# logs are all clone-time inputs. The immutable app/runtime release remains.
remove_targets=(
  etc/matrix
  opt/matrix/env
  opt/matrix/config
  opt/matrix/secrets
  opt/matrix/tls
  opt/matrix/restore-complete
  var/lib/matrix
  home/matrix/home
  home/matrix/.hermes
  home/matrix/.config
  home/matrix/.cache
  home/matrix/.local
  home/matrix/.ssh
  home/matrix/.bash_history
  home/matrix/.zsh_history
  home/matrix/.npmrc
  home/matrix/.netrc
  root/.ssh
  root/.bash_history
  root/.zsh_history
  root/.npmrc
  root/.netrc
  var/lib/systemd/random-seed
  var/lib/cloud
  var/lib/dhcp
  var/lib/NetworkManager
  run/systemd/netif/leases
  etc/netplan/50-cloud-init.yaml
  etc/systemd/system/matrix-restore.service.d/golden.conf
  run/matrix
  var/lib/docker
  var/lib/containerd
  var/log/matrix
  var/log/journal
  var/log/cloud-init.log
  var/log/cloud-init-output.log
  var/log/matrix-builder.log
  swapfile
  swap.img
  tmp
  var/tmp
)
for relative in "${remove_targets[@]}"; do
  remove_path "$relative"
done

# Host keys and persistent network identity must be regenerated by the clone.
for key in "$root"/etc/ssh/ssh_host_*; do
  [ "$key" = "$root/etc/ssh/ssh_host_*" ] || rm -f -- "$key"
done
for lease in "$root"/var/lib/systemd/network/* "$root"/etc/udev/rules.d/70-persistent-net.rules; do
  [ -e "$lease" ] || [ -L "$lease" ] || continue
  rm -rf -- "$lease"
done

mkdir -p "$root/etc" "$root/var/lib/matrix" "$root/tmp" "$root/var/tmp"
: > "$root/etc/machine-id"
remove_path var/lib/dbus/machine-id
chmod 1777 "$root/tmp" "$root/var/tmp"

# Fail closed before recording the baked sanitation evidence. Validation clones
# require every line below, so a missing category can never become selectable.
for relative in "${remove_targets[@]}"; do
  case "$relative" in tmp|var/tmp|var/lib/matrix) continue ;; esac
  target="$(under_root "$relative")"
  if [ -e "$target" ] || [ -L "$target" ]; then
    echo "golden snapshot sanitation verification failed" >&2
    exit 67
  fi
done
if find "$root/etc/ssh" -maxdepth 1 -name 'ssh_host_*' -print -quit 2>/dev/null | grep -q . \
  || [ -s "$root/etc/machine-id" ] \
  || [ -e "$root/var/lib/dbus/machine-id" ] \
  || [ -L "$root/var/lib/dbus/machine-id" ]; then
  echo "golden snapshot host identity sanitation verification failed" >&2
  exit 67
fi

evidence_file="$root/var/lib/matrix/golden-snapshot-sanitized"
printf 'sanitized=true\n' > "$evidence_file"
for relative in "${remove_targets[@]}"; do
  printf 'clean:/%s\n' "$relative" >> "$evidence_file"
done
printf '%s\n' \
  'clean:/etc/ssh/ssh_host_*' \
  'clean:/etc/machine-id' \
  'clean:/var/lib/dbus/machine-id' \
  'clean:/var/lib/docker/volumes' \
  'clean:/var/lib/systemd/network' \
  'clean:/etc/udev/rules.d/70-persistent-net.rules' >> "$evidence_file"
chmod 0644 "$evidence_file"

if [ "$root" = "/" ]; then
  swapoff -a
  sync
  root_source="$(findmnt -n -o SOURCE --target /)"
  root_device="$(readlink -f -- "$root_source")"
  case "$root_device" in
    /dev/*) ;;
    *) echo "golden snapshot root device unavailable" >&2; exit 69 ;;
  esac
  if [ ! -b "$root_device" ]; then
    echo "golden snapshot root device unavailable" >&2
    exit 69
  fi

  zero_fill=/var/lib/matrix-golden-snapshot-zero-fill
  dd_error_file=/run/matrix-golden-snapshot-zero-fill.err
  set +e
  LC_ALL=C dd if=/dev/zero of="$zero_fill" bs=16M conv=fsync status=none 2>"$dd_error_file"
  dd_status=$?
  set -e
  sync
  rm -f -- "$zero_fill"
  sync
  if [ "$dd_status" -eq 0 ] || ! grep -Fq 'No space left on device' "$dd_error_file"; then
    echo "golden snapshot free-block overwrite failed" >&2
    exit 70
  fi

  set +e
  timeout --signal=KILL 600 grep -aF -f "$patterns_file" -- "$root_device" >/dev/null
  scan_status=$?
  set -e
  rm -f -- "$patterns_file" "$dd_error_file"
  patterns_file=""
  dd_error_file=""
  case "$scan_status" in
    1) ;;
    0) echo "golden snapshot raw-device sanitation failed" >&2; exit 71 ;;
    *) echo "golden snapshot raw-device scan failed" >&2; exit 71 ;;
  esac
  printf '%s\n' \
    'clean:free-block-overwrite' \
    'clean:raw-device-callback-and-canary-scan' >> "$evidence_file"
  sync
fi

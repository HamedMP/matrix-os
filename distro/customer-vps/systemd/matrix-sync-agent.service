[Unit]
Description=Matrix OS customer sync agent
After=network-online.target
Wants=network-online.target
ConditionPathExists=/opt/matrix/bin/matrix-sync-agent

[Service]
User=matrix
Group=matrix
EnvironmentFile=/opt/matrix/env/host.env
WorkingDirectory=/opt/matrix
ExecStart=/opt/matrix/bin/matrix-sync-agent
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target

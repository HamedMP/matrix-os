+fn make_resurrected_terminal_pane(rows: usize) -> TerminalPane {
+    let mut geom = PaneGeom::default();
+    geom.cols.set_inner(80);
+    geom.rows.set_inner(rows);
+    TerminalPane::new(
+        1,
+        geom,
+        Style::default(),
+        0,
+        String::new(),
+        Rc::new(RefCell::new(LinkHandler::new())),
+        Rc::new(RefCell::new(None)),
+        Rc::new(RefCell::new(SixelImageStore::default())),
+        Rc::new(RefCell::new(Palette::default())),
+        Rc::new(RefCell::new(HashMap::new())),
+        None,
+        None,
+        false,
+        true,
+        true,
+        true,
+        false,
+        None,
+    )
+}
+
+#[test]
+fn held_resurrected_pane_preserves_viewport_and_history_across_reflow() {
+    let mut terminal_pane = make_resurrected_terminal_pane(10);
+    let mut contents = String::new();
+    for line in 1..=30 {
+        writeln!(&mut contents, "\rMATRIX_SCROLL_{line:05}").unwrap();
+    }
+    terminal_pane.handle_pty_bytes(contents.into_bytes());
+    terminal_pane.scroll_up(5, 1);
+    let viewport_before = terminal_pane.dump_screen(false, None);
+    let anchor_before = viewport_before
+        .lines()
+        .find(|line| line.starts_with("MATRIX_SCROLL_"))
+        .unwrap()
+        .to_owned();
+
+    terminal_pane.hold(None, true, RunCommand::new(PathBuf::from("/bin/false")));
+    let mut resized = terminal_pane.position_and_size();
+    resized.cols.set_inner(81);
+    terminal_pane.set_geom(resized);
+
+    let viewport_after = terminal_pane.dump_screen(false, None);
+    assert_eq!(
+        viewport_after
+            .lines()
+            .find(|line| line.starts_with("MATRIX_SCROLL_"))
+            .unwrap(),
+        anchor_before
+    );
+    assert!(viewport_after.contains("<ENTER> run"));
+    assert!(terminal_pane
+        .dump_screen(true, None)
+        .contains("MATRIX_SCROLL_00001"));
+}

+const SERIALIZED_VIEWPORT_OFFSET_PREFIX: &str = "\u{1b}]1337;matrix-zellij-viewport-offset-v1=";
+const SERIALIZED_VIEWPORT_OFFSET_SUFFIX: &str = "\u{7}";
+
+fn serialize_viewport_offset(serialized: String, viewport_offset: usize) -> String {
+    format!(
+        "{SERIALIZED_VIEWPORT_OFFSET_PREFIX}{viewport_offset}{SERIALIZED_VIEWPORT_OFFSET_SUFFIX}{serialized}"
+    )
+}
+
+pub(crate) fn restore_serialized_viewport_offset(contents: &str) -> (&str, Option<usize>) {
+    let Some(contents_after_prefix) = contents.strip_prefix(SERIALIZED_VIEWPORT_OFFSET_PREFIX)
+    else {
+        return (contents, None);
+    };
+    let Some(suffix_index) = contents_after_prefix.find(SERIALIZED_VIEWPORT_OFFSET_SUFFIX) else {
+        return (contents, None);
+    };
+    let serialized_offset = &contents_after_prefix[..suffix_index];
+    if serialized_offset.is_empty()
+        || serialized_offset.len() > 20
+        || !serialized_offset.bytes().all(|byte| byte.is_ascii_digit())
+    {
+        return (contents, None);
+    }
+    let Ok(viewport_offset) = serialized_offset.parse::<usize>() else {
+        return (contents, None);
+    };
+    let contents_start = suffix_index + SERIALIZED_VIEWPORT_OFFSET_SUFFIX.len();
+    (
+        &contents_after_prefix[contents_start..],
+        Some(viewport_offset),
+    )
+}

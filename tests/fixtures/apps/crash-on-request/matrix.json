{
  "name": "Crash On Request",
  "slug": "crash-on-request",
  "version": "1.0.0",
  "runtime": "node",
  "runtimeVersion": "^1.0.0",
  "listingTrust": "first_party",
  "build": {
    "command": "echo build-done",
    "output": "dist"
  },
  "serve": {
    "start": "node server.js",

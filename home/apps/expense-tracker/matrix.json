{
  "name": "Expense Tracker",
  "description": "Track spending, budgets, and recurring bills with a monthly dashboard.",
  "category": "finance",
  "icon": "expense-tracker",
  "author": "system",
  "version": "2.0.0",
  "storage": {
    "tables": {
      "expenses": {
        "columns": {
          "amount": "float",
          "category": "text",
          "note": "text",
          "spent_at": "timestamptz",
          "recurring": "boolean"
        },
        "indexes": [
          "spent_at",
          "category"
        ]
      },
      "budgets": {
        "columns": {
          "category": "text",
          "monthly_limit": "float"
        },
        "indexes": [
          "category"
        ]
      }
    }
  },
  "runtime": "vite",
  "slug": "expense-tracker",
  "runtimeVersion": "^1.0.0",
  "listingTrust": "first_party",
  "build": {
    "install": "true",
    "command": "vite build --base ./ --outDir dist",
    "output": "dist",
    "timeout": 180,
    "sourceGlobs": [
      "src/**",
      "../_shared/**",
      "../../_shared/**",
      "index.html",
      "matrix.json",
      "vite.config.ts"
    ]
  }
}

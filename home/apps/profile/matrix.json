{
  "name": "Profile",
  "description": "Your Matrix profile page",
  "runtime": "vite",
  "category": "social",
  "icon": "profile",
  "version": "1.0.0",
  "slug": "profile",
  "runtimeVersion": "^1.0.0",
  "listingTrust": "first_party",
  "build": {
    "install": "true",
    "command": "vite build --base ./ --outDir dist",
    "output": "dist",
    "timeout": 180,
    "sourceGlobs": [
      "src/**",
      "../_shared/**",
      "../../_shared/**",
      "index.html",
      "matrix.json",
      "vite.config.ts"
    ]
  }
}

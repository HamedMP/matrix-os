{
  "name": "Chess",
  "description": "Local two-player chess with full legal-move validation, SAN history, and saved games.",
  "runtime": "vite",
  "category": "games",
  "icon": "chess",
  "author": "system",
  "version": "1.0.0",
  "tags": [
    "board",
    "strategy"
  ],
  "runtimeVersion": "^1.0.0",
  "listingTrust": "first_party",
  "slug": "chess",
  "scope": "personal",
  "storage": {
    "tables": {
      "games": {
        "columns": {
          "pgn": "text",
          "result": "text"
        }
      }
    }
  },
  "build": {
    "install": "pnpm install --ignore-workspace --prefer-offline",
    "command": "pnpm build",
    "output": "dist",
    "timeout": 180,
    "sourceGlobs": [
      "src/**",
      "index.html",
      "matrix.json",
      "package.json",
      "vite.config.ts",
      "tsconfig.json"
    ]
  }
}

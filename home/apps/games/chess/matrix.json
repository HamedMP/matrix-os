{
  "name": "Chess",
  "description": "Classic chess with AI opponent",
  "runtime": "vite",
  "category": "games",
  "icon": "game-center",
  "author": "system",
  "version": "1.0.0",
  "tags": [
    "board",
    "strategy"
  ],
  "runtimeVersion": "^1.0.0",
  "listingTrust": "first_party",
  "slug": "chess",
  "build": {
    "install": "true",
    "command": "vite build --base ./ --outDir dist",
    "output": "dist",
    "timeout": 180,
    "sourceGlobs": [
      "src/**",
      "../_shared/**",
      "../../_shared/**",
      "index.html",
      "matrix.json",
      "vite.config.ts"
    ]
  }
}

{
  "name": "Minesweeper",
  "description": "Classic mine-clearing puzzle",
  "runtime": "vite",
  "category": "games",
  "icon": "game-center",
  "author": "system",
  "version": "1.0.0",
  "tags": [
    "puzzle"
  ],
  "runtimeVersion": "^1.0.0",
  "listingTrust": "first_party",
  "slug": "minesweeper",
  "designs": ["flat", "neumorphic", "macos-glass", "win11"],
  "storage": {
    "tables": {
      "times": {
        "columns": {
          "difficulty": "text",
          "rows": "integer",
          "cols": "integer",
          "mines": "integer",
          "seconds": "integer"
        },
        "indexes": ["difficulty", "rows", "cols", "mines"]
      }
    }
  },
  "build": {
    "install": "true",
    "command": "vite build --base ./ --outDir dist",
    "output": "dist",
    "timeout": 180,
    "sourceGlobs": [
      "src/**",
      "../_shared/**",
      "../../_shared/**",
      "index.html",
      "matrix.json",
      "vite.config.ts"
    ]
  }
}

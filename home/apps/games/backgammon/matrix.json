{
  "name": "Backgammon",
  "description": "Local two-player backgammon with a full legal-move engine, dice, hitting and bearing off.",
  "runtime": "vite",
  "category": "games",
  "icon": "game-center",
  "author": "system",
  "version": "1.0.0",
  "tags": [
    "board"
  ],
  "runtimeVersion": "^1.0.0",
  "listingTrust": "first_party",
  "slug": "backgammon",
  "storage": {
    "tables": {
      "matches": {
        "columns": {
          "winner": "text",
          "points": "integer",
          "created_at": "timestamptz"
        }
      }
    }
  },
  "build": {
    "install": "true",
    "command": "vite build --base ./ --outDir dist",
    "output": "dist",
    "timeout": 180,
    "sourceGlobs": [
      "src/**",
      "../_shared/**",
      "../../_shared/**",
      "index.html",
      "matrix.json",
      "vite.config.ts"
    ]
  }
}

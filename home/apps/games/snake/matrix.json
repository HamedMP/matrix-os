{
  "name": "Snake",
  "description": "Classic snake game with increasing speed",
  "runtime": "vite",
  "category": "games",
  "icon": "game-center",
  "author": "system",
  "version": "1.0.0",
  "tags": [
    "arcade"
  ],
  "runtimeVersion": "^1.0.0",
  "listingTrust": "first_party",
  "slug": "snake",
  "storage": {
    "tables": {
      "scores": {
        "columns": {
          "score": "integer",
          "best": "integer"
        },
        "indexes": [
          "best"
        ]
      }
    }
  },
  "build": {
    "install": "true",
    "command": "vite build --base ./ --outDir dist",
    "output": "dist",
    "timeout": 180,
    "sourceGlobs": [
      "src/**",
      "../_shared/**",
      "../../_shared/**",
      "index.html",
      "matrix.json",
      "vite.config.ts"
    ]
  }
}

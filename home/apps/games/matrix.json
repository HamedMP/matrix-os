{
  "name": "Game Center",
  "description": "Browse, discover, and play games",
  "runtime": "vite",
  "category": "utilities",
  "icon": "game-center",
  "author": "system",
  "version": "2.0.0",
  "slug": "games",
  "runtimeVersion": "^1.0.0",
  "listingTrust": "first_party",
  "build": {
    "install": "true",
    "command": "vite build --base ./ --outDir dist",
    "output": "dist",
    "timeout": 180,
    "sourceGlobs": [
      "src/**",
      "../_shared/**",
      "../../_shared/**",
      "index.html",
      "matrix.json",
      "vite.config.ts"
    ]
  }
}

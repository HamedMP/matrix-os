{
  "name": "Whiteboard",
  "slug": "whiteboard",
  "description": "Infinite sketching and diagramming canvas with shapes, sticky notes, and export.",
  "category": "productivity",
  "icon": "whiteboard",
  "author": "system",
  "version": "1.0.0",
  "runtime": "vite",
  "runtimeVersion": "^1.0.0",
  "scope": "personal",
  "storage": {
    "tables": {
      "scenes": {
        "columns": {
          "name": "text",
          "doc": "jsonb"
        }
      }
    }
  },
  "build": {
    "install": "true",
    "command": "vite build --base ./ --outDir dist",
    "output": "dist",
    "timeout": 180,
    "sourceGlobs": [
      "src/**",
      "../_shared/**",
      "index.html",
      "matrix.json",
      "vite.config.ts"
    ]
  },
  "listingTrust": "first_party"
}

{
  "name": "Stickies",
  "description": "macOS Stickies style floating glass notes for your desktop",
  "runtime": "vite",
  "category": "productivity",
  "icon": "stickies",
  "author": "system",
  "version": "1.0.0",
  "slug": "stickies",
  "designs": ["macos-glass"],
  "runtimeVersion": "^1.0.0",
  "listingTrust": "first_party",
  "build": {
    "install": "true",
    "command": "vite build --base ./ --outDir dist",
    "output": "dist",
    "timeout": 180,
    "sourceGlobs": [
      "src/**",
      "../_shared/**",
      "../../_shared/**",
      "index.html",
      "matrix.json",
      "vite.config.ts"
    ]
  }
}

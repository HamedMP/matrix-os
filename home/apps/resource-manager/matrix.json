{
  "name": "Resource Manager",
  "description": "Monitor Matrix OS services, processes, and resource usage",
  "runtime": "vite",
  "category": "utility",
  "icon": "resource-manager",
  "author": "system",
  "version": "1.0.0",
  "slug": "resource-manager",
  "runtimeVersion": "^1.0.0",
  "listingTrust": "first_party",
  "build": {
    "install": "true",
    "command": "vite build --base ./ --outDir dist",
    "output": "dist",
    "timeout": 180,
    "sourceGlobs": [
      "src/**",
      "../_shared/**",
      "../../_shared/**",
      "index.html",
      "matrix.json",
      "vite.config.ts"
    ]
  }
}

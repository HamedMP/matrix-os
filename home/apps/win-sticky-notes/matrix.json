{
  "name": "Sticky Notes",
  "description": "Windows 11 style sticky notes with pastel colors and a notes list, autosaved to your Matrix home",
  "runtime": "vite",
  "category": "productivity",
  "icon": "sticky-notes",
  "author": "system",
  "version": "1.0.0",
  "slug": "win-sticky-notes",
  "designs": ["win11"],
  "runtimeVersion": "^1.0.0",
  "listingTrust": "first_party",
  "build": {
    "install": "true",
    "command": "vite build --base ./ --outDir dist",
    "output": "dist",
    "timeout": 180,
    "sourceGlobs": [
      "src/**",
      "../_shared/**",
      "../../_shared/**",
      "index.html",
      "matrix.json",
      "vite.config.ts"
    ]
  }
}

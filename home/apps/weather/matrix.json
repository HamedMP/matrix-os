{
  "name": "Weather",
  "description": "Beautiful weather with forecasts",
  "runtime": "vite",
  "category": "utility",
  "icon": "weather",
  "author": "system",
  "version": "1.0.0",
  "slug": "weather",
  "runtimeVersion": "^1.0.0",
  "listingTrust": "first_party",
  "storage": {
    "tables": {
      "locations": {
        "columns": {
          "name": "text",
          "latitude": "float",
          "longitude": "float",
          "is_default": "boolean",
          "created_at": "timestamptz"
        },
        "indexes": [
          "is_default",
          "created_at"
        ]
      }
    }
  },
  "build": {
    "install": "true",
    "command": "vite build --base ./ --outDir dist",
    "output": "dist",
    "timeout": 180,
    "sourceGlobs": [
      "src/**",
      "../_shared/**",
      "../../_shared/**",
      "index.html",
      "matrix.json",
      "vite.config.ts"
    ]
  }
}

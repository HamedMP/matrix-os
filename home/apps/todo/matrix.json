{
  "name": "Todo",
  "description": "Fast personal task manager with inbox capture, smart lists, and recurring tasks.",
  "category": "productivity",
  "icon": "todo",
  "author": "system",
  "version": "2.0.0",
  "scope": "personal",
  "storage": {
    "tables": {
      "tasks": {
        "columns": {
          "title": "text",
          "text": "text",
          "notes": "text",
          "due": "timestamptz",
          "priority": "integer",
          "project": "text",
          "category": "text",
          "status": "text",
          "done": "boolean",
          "recur": "text"
        },
        "indexes": [
          "due",
          "project",
          "status"
        ]
      }
    }
  },
  "runtime": "vite",
  "slug": "todo",
  "runtimeVersion": "^1.0.0",
  "listingTrust": "first_party",
  "build": {
    "install": "true",
    "command": "vite build --base ./ --outDir dist",
    "output": "dist",
    "timeout": 180,
    "sourceGlobs": [
      "src/**",
      "../_shared/**",
      "../../_shared/**",
      "index.html",
      "matrix.json",
      "vite.config.ts"
    ]
  }
}

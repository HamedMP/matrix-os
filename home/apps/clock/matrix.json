{
  "name": "Clock",
  "description": "World clock, alarms, timers, and stopwatch.",
  "runtime": "vite",
  "category": "utility",
  "icon": "clock",
  "author": "system",
  "version": "1.1.0",
  "slug": "clock",
  "runtimeVersion": "^1.0.0",
  "listingTrust": "first_party",
  "storage": {
    "tables": {
      "zones": {
        "columns": {
          "tz": "text",
          "position": "integer"
        },
        "indexes": [
          "position"
        ],
        "uniqueIndexes": [
          "tz"
        ]
      },
      "alarms": {
        "columns": {
          "time": "text",
          "label": "text",
          "repeat": "text",
          "enabled": "boolean"
        },
        "indexes": [
          "time"
        ]
      }
    }
  },
  "build": {
    "install": "true",
    "command": "vite build --base ./ --outDir dist",
    "output": "dist",
    "timeout": 180,
    "sourceGlobs": [
      "src/**",
      "../_shared/**",
      "../../_shared/**",
      "index.html",
      "matrix.json",
      "vite.config.ts"
    ]
  }
}

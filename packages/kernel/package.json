{
  "name": "@matrix-os/kernel",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./security/external-content": {
      "types": "./src/security/external-content.ts",
      "import": "./dist/security/external-content.js",
      "default": "./dist/security/external-content.js"
    },
    "./security/audit": {
      "types": "./src/security/audit.ts",
      "import": "./dist/security/audit.js",
      "default": "./dist/security/audit.js"
    },
    "./security/ssrf-guard": {
      "types": "./src/security/ssrf-guard.ts",
      "import": "./dist/security/ssrf-guard.js",
      "default": "./dist/security/ssrf-guard.js"
    },
    "./skill-registry": {
      "types": "./src/skill-registry.ts",
      "import": "./dist/skill-registry.js",
      "default": "./dist/skill-registry.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.2.3",
    "@types/turndown": "^5.0.6",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.74",
    "@matrix-os/gateway": "workspace:*",
    "@matrix-os/mcp-browser": "workspace:*",
    "@mozilla/readability": "^0.6.0",
    "better-sqlite3": "^12.10.0",
    "chokidar": "^5.0.0",
    "drizzle-orm": "^0.45.2",
    "linkedom": "^0.18.12",
    "turndown": "^7.2.4",
    "zod": "^4.4.3"
  }
}

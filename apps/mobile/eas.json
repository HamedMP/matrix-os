{
  "cli": {
    "version": ">= 20.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "24.14.0",
      "pnpm": "10.33.4"
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "development-device": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "extends": "base",
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      // EXPO_PUBLIC_POSTHOG_API_KEY is intentionally NOT set here — provide it as
      // an EAS secret/env var so the key is never committed. When it is absent the
      // app runs analytics-free (see apps/mobile/lib/analytics.ts).
      "env": {
        "EXPO_PUBLIC_CODING_AGENTS_MOBILE_WORKSPACE": "1",
        "EXPO_PUBLIC_POSTHOG_HOST": "https://eu.i.posthog.com"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal"
      },
      "ios": {
        // Apple ID auth. ascAppId + appleTeamId are intentionally omitted so EAS
        // auto-resolves them (finds/creates the ASC app by bundleIdentifier and
        // derives the team from your authenticated session) during submit.
        // After the first successful submit, paste the real values here to skip
        // lookups: "ascAppId": "1234567890", "appleTeamId": "ABCDE12345".
        "appleId": "thehamedmp@gmail.com",
        "ascAppId": "6785629815",
        "appleTeamId": "PX4JL74Y2K"
        // Alternative (fully non-interactive CI): use an App Store Connect API key:
        //   "ascApiKeyPath": "./asc-api-key.p8",
        //   "ascApiKeyId": "XXXXXXXXXX",
        //   "ascApiKeyIssuerId": "00000000-0000-0000-0000-000000000000"
      }
    }
  }
}

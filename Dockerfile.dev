# Matrix OS -- Development container
# Source code is bind-mounted from the host, not copied.
# HMR via tsx watch (gateway) + next dev with Turbopack (shell).

FROM node:24-alpine

# System deps for native addons (node-pty, better-sqlite3, sqlite-vec)
RUN apk add --no-cache git python3 make g++ linux-headers bash su-exec cmake \
    zsh curl shadow

# pnpm via corepack (Agent SDK bundles its own claude runtime)
RUN corepack enable && corepack prepare pnpm@10.6.2 --activate

# AI coding CLIs
RUN npm install -g \
    @anthropic-ai/claude-code@2.1.91 \
    @openai/codex@0.118.0 \
    opencode-ai@1.3.13

# QMD semantic search (BM25 + optional vector search)
RUN npm install -g @tobilu/qmd

# GitHub CLI (release binary; alpine's github-cli package trails a few versions).
# GH_SHA256 must match the upstream gh_${GH_VERSION}_checksums.txt entry for
# gh_${GH_VERSION}_linux_amd64.tar.gz -- bump both values together.
ARG GH_VERSION=2.86.0
ARG GH_SHA256=f3b08bd6a28420cc2229b0a1a687fa25f2b838d3f04b297414c1041ca68103c7
RUN set -eux; \
    wget -qO /tmp/gh.tgz "https://github.com/cli/cli/releases/download/v${GH_VERSION}/gh_${GH_VERSION}_linux_amd64.tar.gz"; \
    echo "${GH_SHA256}  /tmp/gh.tgz" | sha256sum -c -; \
    tar -xzf /tmp/gh.tgz -C /tmp; \
    mv "/tmp/gh_${GH_VERSION}_linux_amd64/bin/gh" /usr/local/bin/gh; \
    rm -rf /tmp/gh.tgz "/tmp/gh_${GH_VERSION}_linux_amd64"

# Non-root user (Agent SDK refuses bypassPermissions as root)
RUN addgroup -S matrixos && adduser -S matrixos -G matrixos -h /home/matrixos -s /bin/zsh

# Give matrixos write access to global npm so claude/codex/opencode
# can auto-update themselves from inside the container.
RUN chown -R matrixos:matrixos /usr/local/lib/node_modules /usr/local/bin

# Powerlevel10k + pinned zsh plugins
RUN mkdir -p /home/matrixos/.zsh/themes /home/matrixos/.zsh/plugins && \
    git clone --branch v1.20.0 --depth=1 https://github.com/romkatv/powerlevel10k.git \
      /home/matrixos/.zsh/themes/powerlevel10k && \
    git clone --branch v0.7.1 --depth=1 https://github.com/zsh-users/zsh-autosuggestions \
      /home/matrixos/.zsh/plugins/zsh-autosuggestions && \
    git clone --branch 0.8.0 --depth=1 https://github.com/zsh-users/zsh-syntax-highlighting \
      /home/matrixos/.zsh/plugins/zsh-syntax-highlighting && \
    chown -R matrixos:matrixos /home/matrixos/.zsh

# Zsh + p10k config for matrixos user
COPY distro/zshrc /home/matrixos/.zshrc
COPY distro/p10k.zsh /home/matrixos/.p10k.zsh
RUN chown matrixos:matrixos /home/matrixos/.zshrc /home/matrixos/.p10k.zsh

WORKDIR /app

# No source copy - bind mounted from host
# No build step - dev servers run live

EXPOSE 3000 4000

# Entrypoint runs as root for setup, drops to matrixos for services
ENTRYPOINT ["/app/distro/docker-dev-entrypoint.sh"]

# Matrix OS -- Development container
# Source code is bind-mounted from the host, not copied.
# HMR via tsx watch (gateway) + next dev with Turbopack (shell).

FROM node:24-alpine

# System deps for native addons (node-pty, better-sqlite3, sqlite-vec)
RUN apk add --no-cache git python3 make g++ linux-headers bash su-exec cmake \
    zsh curl shadow

# pnpm via corepack (Agent SDK bundles its own claude runtime)
RUN corepack enable && corepack prepare pnpm@latest --activate

# Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# QMD semantic search (BM25 + optional vector search)
RUN npm install -g @tobilu/qmd

# Non-root user (Agent SDK refuses bypassPermissions as root)
RUN addgroup -S matrixos && adduser -S matrixos -G matrixos -h /home/matrixos -s /bin/zsh

# Zsh config for matrixos user
COPY distro/zshrc /home/matrixos/.zshrc
RUN chown matrixos:matrixos /home/matrixos/.zshrc

WORKDIR /app

# No source copy - bind mounted from host
# No build step - dev servers run live

EXPOSE 3000 4000

# Entrypoint runs as root for setup, drops to matrixos for services
ENTRYPOINT ["/app/distro/docker-dev-entrypoint.sh"]

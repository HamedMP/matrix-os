{
  "name": "matrix-os",
  "version": "0.9.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "bin": {
    "matrixos": "./bin/matrixos.mjs",
    "matrix": "./bin/matrixos.mjs",
    "mos": "./bin/matrixos.mjs"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "dev": "bun run --filter '@matrix-os/gateway' dev & bun run --filter '@matrix-os/proxy' dev & bun run --filter './shell' dev",
    "dev:kernel": "bun run --filter '@matrix-os/kernel' dev",
    "dev:gateway": "bun run --filter '@matrix-os/gateway' dev",
    "dev:shell": "bun run --filter shell dev",
    "dev:www": "bun run --filter www dev",
    "dev:proxy": "bun run --filter '@matrix-os/proxy' dev",
    "dev:platform": "bun run --filter '@matrix-os/platform' dev",
    "docker": "docker compose -f docker-compose.dev.yml up",
    "docker:full": "docker compose -f docker-compose.dev.yml --profile full up",
    "docker:all": "docker compose -f docker-compose.dev.yml --profile full --profile obs up",
    "docker:multi": "docker compose -f docker-compose.dev.yml --profile full --profile multi up",
    "docker:stop": "docker compose -f docker-compose.dev.yml --profile full --profile obs --profile multi stop",
    "docker:restart": "docker compose -f docker-compose.dev.yml restart dev",
    "docker:logs": "docker compose -f docker-compose.dev.yml logs -f dev",
    "docker:shell": "docker compose -f docker-compose.dev.yml exec -u matrixos dev sh",
    "docker:build": "docker compose -f docker-compose.dev.yml build --no-cache",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "pnpm --filter '@matrix-os/kernel' exec tsc --noEmit && pnpm --filter '@matrix-os/gateway' exec tsc --noEmit && pnpm --filter '@matrix-os/platform' exec tsc --noEmit -p tsconfig.typecheck.json && pnpm --filter '@matrix-os/proxy' exec tsc --noEmit",
    "check:patterns": "./scripts/review/check-patterns.sh",
    "check:patterns:diff": "./scripts/review/check-patterns.sh --diff main",
    "lint": "bun run --filter './shell' lint"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "node-pty",
      "esbuild",
      "sharp",
      "unrs-resolver",
      "@next/swc-linux-arm64-musl",
      "@next/swc-linux-x64-musl"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "kysely-codegen>kysely": "^0.28.0"
      }
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@vitest/coverage-v8": "^4.0.18",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@types/pg": "^8.18.0",
    "pg": "^8.20.0"
  }
}

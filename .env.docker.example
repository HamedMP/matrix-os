# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional (for full stack profile)
PLATFORM_SECRET=dev-secret
GEMINI_API_KEY=
GRAFANA_ADMIN_PASSWORD=matrixos

# Optional (for channel testing)
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=

# Clerk auth (Docker dev). The dev image does NOT bake a Clerk key. Without one
# the shell loops on /sign-in (Clerk Keyless mode). Pick ONE of the two blocks:
#
# 1) Real login -- keys from a free Clerk dev instance (clerk.com):
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
#
# 2) Skip auth (local dev only -- NEVER set in production). Lands on the desktop
#    with no login; mirrors the dev:mobile-shell script:
# E2E_TEST_BYPASS=1
# NEXT_PUBLIC_E2E_TEST_BYPASS=1
# MATRIX_AUTH_ALLOW_INSECURE_DEV=1
#
# After editing, recreate the container -- restart (including bun run docker:restart,
# which wraps docker compose restart) does not reload env_file:
#   docker compose -f docker-compose.dev.yml up -d
